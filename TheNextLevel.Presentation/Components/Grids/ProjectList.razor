@using TheNextLevel.Presentation.Components.Cards
@inject IProjectService ProjectService

<VirtualizedList TItem="ProjectDto"
                 ItemsProvider="LoadProjectsProvider"
                 WrapperClass="projects-grid"
                 EmptyMessage="No projects found. Create your first project!"
                 @ref="_list">
    <ItemTemplate Context="project">
        <ProjectCard Project="project" />
    </ItemTemplate>
</VirtualizedList>

@code {
    [Parameter]
    public MissionDto? Mission { get; set; }

    private VirtualizedList<ProjectDto>? _list;

    private async ValueTask<ItemsProviderResult<ProjectDto>> LoadProjectsProvider(ItemsProviderRequest request)
    {
        var result = await ProjectService.ListByMissionAsync(Mission?.Id ?? 0, request.StartIndex, request.Count);
        return new ItemsProviderResult<ProjectDto>(result?.Items ?? Array.Empty<ProjectDto>(), result?.TotalCount ?? 0);
    }

    public async Task RefreshAsync()
    {
        if (_list is not null)
            await _list.RefreshAsync();
    }
}
