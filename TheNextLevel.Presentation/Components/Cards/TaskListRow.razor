@using TheNextLevel.Application.DTOs
@inject NavigationManager Navigation

<div class="task-row @(IsComplete ? "is-complete" : "")"
     style="--accent-color: @AccentColor"
     @onclick="NavigateToDetail">
    <div class="task-accent" style="background: @AccentColor"></div>
    <div class="task-body">
        <div class="task-top">
            <div class="task-text">
                <div class="task-name">@Task.Name</div>
                <div class="task-breadcrumb">
                    @Mission?.Name
                    <span class="breadcrumb-sep">›</span>
                    @Project?.Name
                </div>
                @if (!string.IsNullOrEmpty(Task.Description))
                {
                    <div class="description-scroll description-scroll--desktop">
                        <div class="description-content">
                            <span class="description-text">@Task.Description</span>
                            <span class="description-text">@Task.Description</span>
                        </div>
                    </div>
                }
            </div>
            <div class="task-status @StatusClass">
                <div class="status-dot"></div>
                @StatusLabel
            </div>
            <button class="task-menu-btn task-menu-btn--always" title="Task menu" @onclick:stopPropagation="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
                </svg>
            </button>
        </div>
        @if (!string.IsNullOrEmpty(Task.Description))
        {
            <div class="description-scroll description-scroll--mobile">
                <div class="description-content">
                    <span class="description-text">@Task.Description</span>
                    <span class="description-text">@Task.Description</span>
                </div>
            </div>
        }
    </div>
    <div class="task-controls">
        <button class="task-menu-btn" title="Task menu" @onclick:stopPropagation="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
            </svg>
        </button>
        <svg class="chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 18l6-6-6-6"/>
        </svg>
    </div>
</div>

@code {
    [Parameter] public TaskDto Task { get; set; } = null!;
    [Parameter] public ProjectDto? Project { get; set; }
    [Parameter] public MissionDto? Mission { get; set; }
    [Parameter] public string AccentColor { get; set; } = "rgba(139,69,19,0.4)";

    private bool IsComplete => Task.Status == TaskState.Completed;

    private string StatusClass => Task.Status switch
    {
        TaskState.Active    => "status-active",
        TaskState.Completed => "status-complete",
        TaskState.OnHold    => "status-onhold",
        _                   => "status-inactive"
    };

    private string StatusLabel => Task.Status switch
    {
        TaskState.Active    => "Active",
        TaskState.Completed => "Completed",
        TaskState.OnHold    => "On Hold",
        _                   => "Inactive"
    };

    private void NavigateToDetail()
    {
        Navigation.NavigateTo($"/task/{Task.Id}");
    }
}
