@page "/project/{Id:int}"

@using Microsoft.JSInterop
@using TheNextLevel.Application.DTOs
@using TheNextLevel.Application.Interfaces
@using TheNextLevel.Presentation.Components.Cards
@using TheNextLevel.Presentation.Components.Grids
@using TheNextLevel.Presentation.Dialogs
@using TheNextLevel.Presentation.Components.Buttons

@inject IProjectService ProjectService
@inject NavigationManager Navigation
@inject ITaskService TaskService
@inject IJSRuntime JSRuntime

<main class="main-content">

    <div class="project-header">
        <div class="header-top-bar">
            <button class="back-btn" @onclick="NavigateBack">
                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back
            </button>
            @if (_project != null)
            {
                <div class="header-actions">
                    <button class="header-action-btn" @onclick="ShowEditDialog">
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Edit
                    </button>
                    <button class="header-action-btn danger" @onclick="ShowDeleteDialog">
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                        Delete
                    </button>
                </div>

                <div class="hero-more-wrap">
                    <button class="hero-more-btn" @onclick="() => _isMoreMenuOpen = !_isMoreMenuOpen">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
                        </svg>
                    </button>
                </div>
            }
        </div>
        <div class="project-title-block">
            @if (_isLoading)
            {
                <div class="project-name loading-text">Loading…</div>
            }
            else if (_errorMessage != null)
            {
                <div class="error-message">@_errorMessage</div>
            }
            else if (_project != null)
            {
                <div class="project-name">@_project.Name</div>
                @if (!string.IsNullOrEmpty(_project.Description))
                {
                    <div class="project-desc">@_project.Description</div>
                }
            }
        </div>
    </div>

    @if (_isMoreMenuOpen)
    {
        <div class="more-overlay" @onclick="() => _isMoreMenuOpen = false"></div>
        <div class="more-dropdown">
            <button class="dropdown-item" @onclick="() => { _isMoreMenuOpen = false; ShowEditDialog(); }">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit Project
            </button>
            <button class="dropdown-item danger" @onclick="() => { _isMoreMenuOpen = false; ShowDeleteDialog(); }">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete Project
            </button>
        </div>
    }

    @if (_project != null)
    {
        <div class="stats-band">
            <div class="stat-cell">
                <span class="stat-value highlight">@_statActive</span>
                <span class="stat-label">Active</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-cell">
                <span class="stat-value">@_statInactive</span>
                <span class="stat-label">Inactive</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-cell">
                <span class="stat-value">@_statOnHold</span>
                <span class="stat-label">On Hold</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-cell">
                <span class="stat-value">@_statDone</span>
                <span class="stat-label">Done</span>
            </div>
        </div>
    }

    @if (_project != null)
    {
        <div class="content-body">
            <div class="section-header">
                <div class="section-left">
                    <span class="section-title">Tasks</span>
                </div>
                <button class="new-task-btn" @onclick="OpenCreateTask">
                    <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14"/>
                    </svg>
                    New Task
                </button>
            </div>

            <div class="filter-bar">
                <button class="filter-btn @(_filter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>All</button>
                <button class="filter-btn @(_filter == "active" ? "active" : "")" @onclick='() => SetFilter("active")'>Active</button>
                <button class="filter-btn @(_filter == "inactive" ? "active" : "")" @onclick='() => SetFilter("inactive")'>Inactive</button>
                <button class="filter-btn @(_filter == "onhold" ? "active" : "")" @onclick='() => SetFilter("onhold")'>On Hold</button>
                <button class="filter-btn @(_filter == "completed" ? "active" : "")" @onclick='() => SetFilter("completed")'>Completed</button>
            </div>

            <TaskGrid
                @ref="_taskGrid"
                Project="@_project"
                FilterStatus="@_filter"
                OnEditRequested="HandleEditTask"
                OnDeleteRequested="HandleDeleteTask" />
        </div>
    }
</main>

<EditModal
    Item="@_project"
    @ref="_editModal"
    OnResult="HandleProjectUpdated"
    OnCancel="CloseEditDialog" />

<ConfirmDeleteDialog
    IsVisible="@_isDeleteDialogVisible"
    ItemName="@_project?.Name"
    ItemType="project"
    OnCancel="() => _isDeleteDialogVisible = false"
    OnConfirm="OnDeleteConfirmed" />

<CreateModal
    IsVisible="@_showCreateTaskModal"
    ItemType="ModalType.Task"
    ExistingParent="@_project"
    OnResult="HandleTaskCreated"
    OnCancel="CloseCreateTask" />

<EditModal
    Item="@_selectedTask"
    @ref="_editTaskModal"
    OnResult="HandleTaskUpdated"
    OnCancel="CloseEditTask" />

<ConfirmDeleteDialog
    IsVisible="@_showDeleteTaskDialog"
    OnCancel="CloseDeleteTask"
    OnConfirm="HandleDeleteTaskConfirmed"
    ItemName="@(_selectedTask?.Name ?? "this task")"
    ItemType="task" />

@code {
    [Parameter]
    public int Id { get; set; }

    private bool _isLoading = true;
    private bool _isDeleteDialogVisible = false;
    private ProjectDto? _project;
    private string? _errorMessage = null;
    private EditModal? _editModal;
    private EditModal? _editTaskModal;

    private TaskGrid? _taskGrid;
    private TaskDto? _selectedTask;
    private bool _showCreateTaskModal;
    private bool _showDeleteTaskDialog;
    private string _filter = "all";
    private bool _isMoreMenuOpen = false;
    private int _statActive   = 0;
    private int _statInactive = 0;
    private int _statOnHold   = 0;
    private int _statDone     = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadProject();
    }

    private async Task LoadProject()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            _project = await ProjectService.GetByIdAsync(Id);

            if (_project == null)
            {
                _errorMessage = "Project could not be found.";
            }
            else
            {
                var taskResult = await TaskService.ListByProjectAsync(Id, 0, 1000);
                _statActive   = taskResult.Items.Count(t => t.Status == TaskState.Active);
                _statInactive = taskResult.Items.Count(t => t.Status == TaskState.Inactive);
                _statOnHold   = taskResult.Items.Count(t => t.Status == TaskState.OnHold);
                _statDone     = taskResult.Items.Count(t => t.Status == TaskState.Completed);
            }

            _isLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading project: {ex.Message}");
            _errorMessage = "An error occurred while loading the project.";
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void SetFilter(string f) => _filter = f;

    private async Task RefreshStats()
    {
        var taskResult = await TaskService.ListByProjectAsync(Id, 0, 1000);
        _statActive   = taskResult.Items.Count(t => t.Status == TaskState.Active);
        _statInactive = taskResult.Items.Count(t => t.Status == TaskState.Inactive);
        _statOnHold   = taskResult.Items.Count(t => t.Status == TaskState.OnHold);
        _statDone     = taskResult.Items.Count(t => t.Status == TaskState.Completed);
        StateHasChanged();
    }

    // === PROJECT CRUD ===
    private void ShowDeleteDialog() => _isDeleteDialogVisible = true;
    private void ShowEditDialog() => _editModal?.ShowDialog();
    private void CloseEditDialog() => _editModal?.HideDialog();

    private async Task OnDeleteConfirmed()
    {
        if (_project != null)
        {
            try
            {
                await ProjectService.DeleteAsync(_project.Id);
                Navigation.NavigateTo("/");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting project: {ex.Message}");
                _errorMessage = "An error occurred while deleting the project.";
            }
        }

        _isDeleteDialogVisible = false;
    }

    private async Task HandleProjectUpdated(IItemDto updatedProject)
    {
        _project = (ProjectDto)updatedProject;
        CloseEditDialog();
        StateHasChanged();
    }

    // === TASK CRUD ===
    private void OpenCreateTask() => _showCreateTaskModal = true;
    private void CloseCreateTask() => _showCreateTaskModal = false;

    private async Task HandleTaskCreated(IItemDto? task)
    {
        _showCreateTaskModal = false;
        if (_taskGrid != null) await _taskGrid.RefreshList();
        await RefreshStats();
    }

    private void HandleEditTask(TaskDto task)
    {
        _selectedTask = task;
        _editTaskModal?.ShowDialog();
    }

    private void CloseEditTask()
    {
        _editTaskModal?.HideDialog();
        _selectedTask = null;
    }

    private async Task HandleTaskUpdated(IItemDto updatedTask)
    {
        CloseEditTask();
        if (_taskGrid != null) await _taskGrid.RefreshList();
        await RefreshStats();
    }

    private void HandleDeleteTask(TaskDto task)
    {
        _selectedTask = task;
        _showDeleteTaskDialog = true;
    }

    private void CloseDeleteTask()
    {
        _showDeleteTaskDialog = false;
        _selectedTask = null;
    }

    private async Task HandleDeleteTaskConfirmed()
    {
        if (_selectedTask != null)
            await TaskService.DeleteAsync(_selectedTask.Id);
        CloseDeleteTask();
        if (_taskGrid != null) await _taskGrid.RefreshList();
        await RefreshStats();
    }

    private async Task NavigateBack()
    {
        await JSRuntime.InvokeVoidAsync("history.back");
    }
}
