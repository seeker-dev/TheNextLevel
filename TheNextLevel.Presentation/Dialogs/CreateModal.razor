@using TheNextLevel.Application.Interfaces
@using TheNextLevel.Application.DTOs

@inject IMissionService MissionService
@inject IProjectService ProjectService
@inject ITaskService TaskService

@if (IsVisible)
{
<div class="dialog-overlay visible">
    <div class="dialog-container" @onclick:stopPropagation="true">
        <div class="modal-header">
            <div class="title-group">
                <span class="eyebrow">New</span>
                <span class="modal-title">@ItemType</span>
            </div>
            <button type="button" class="close-btn" aria-label="Close" @onclick="Cancel">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <div class="modal-body">
            <div class="field-group">
                <span class="field-label">Name</span>
                <input type="text" @bind="itemName" class="opus-input" placeholder="Enter @ItemType name" />
            </div>
            <div class="field-group">
                <span class="field-label">Description <span class="field-optional">optional</span></span>
                <textarea @bind="itemDescription" class="opus-textarea" placeholder="Brief description..."></textarea>
            </div>

            @if (ItemType == ModalType.Task || ItemType == ModalType.Project)
            {
                <ParentSelector
                    @bind-SelectedId="_selectedParentId"
                    Items="_parentItems"
                    IsLoading="_isLoading"
                    Label="@_parentLabel" />
            }
        </div>

        <div class="modal-footer">
            <button type="button" class="btn-ghost" @onclick="Cancel">Cancel</button>
            <button type="button" class="btn-primary" @onclick="Confirm">
                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14"/>
                </svg>
                Create
            </button>
        </div>
    </div>
</div>

<DiscardConfirmationDialog
    IsVisible="_showDiscardConfirmation"
    OnConfirm="OnDiscardConfirm"
    OnCancel="OnDiscardCancel" />
}
@code {
    [Parameter]
    public required bool IsVisible { get; set; }
    [Parameter]
    public required ModalType ItemType { get; set; }
    [Parameter]
    public IItemDto? ExistingParent { get; set; }

    // Events
    [Parameter]
    public required EventCallback<IItemDto?> OnResult { get; set; }
    [Parameter]
    public required EventCallback OnCancel { get; set; }

    private bool _isLoading = false;
    private List<IItemDto> _parentItems = [];
    private string _parentLabel => ItemType == ModalType.Task ? "project" : "mission";
    private string _selectedParentId = string.Empty;
    private IItemDto? selectedParent => _parentItems.FirstOrDefault(p => p.Id.ToString() == _selectedParentId);

    // Pagination
    private int _currentPage = 1;
    private int _pageSize = 10;

    // Input binding
    private string itemName = string.Empty;
    private string itemDescription = string.Empty;

    // Discard confirmation
    private bool _showDiscardConfirmation = false;
    private string _initialParentId = string.Empty;
    private bool _hasUnsavedChanges =>
        !string.IsNullOrEmpty(itemName) ||
        !string.IsNullOrEmpty(itemDescription) ||
        _selectedParentId != _initialParentId;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible)
        {
            _currentPage = 0;
            _parentItems.Clear();
            await Load();
        }
    }

    public async Task Load()
    {
        itemName = string.Empty;
        itemDescription = string.Empty;

        _isLoading = true;
        try
        {
            if (ItemType == ModalType.Project)
                _parentItems = await DialogHelper.LoadAllAsync<MissionDto>(MissionService.ListAsync, _pageSize);
            else if (ItemType == ModalType.Task)
                _parentItems = await DialogHelper.LoadAllAsync<ProjectDto>(ProjectService.ListAsync, _pageSize);

            _selectedParentId = ExistingParent is not null ? (_parentItems.FirstOrDefault(i => i.Id == ExistingParent.Id)?.Id.ToString() ?? string.Empty) : string.Empty;
            _initialParentId = _selectedParentId;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMore()
    {
        _currentPage++;
        await Load();
    }

    private void Select(IItemDto item)
    {
        _selectedParentId = item.Id.ToString();
    }

    private async Task Confirm()
    {
        if (!(HasSelectedParent || HasValidMission))
        {
            // Show validation error (not implemented here)
            return;
        }

        if (ItemType == ModalType.Mission)
        {
            await CreateMission();            
        }
        else if (ItemType == ModalType.Project)
        {
            await CreateProject();
        }
        else if (ItemType == ModalType.Task)
        {
            await CreateTask();
        }
    }

    private async Task Cancel()
    {
        if (_hasUnsavedChanges)
        {
            _showDiscardConfirmation = true;
            return;
        }
        await OnCancel.InvokeAsync();
    }

    private async Task OnDiscardConfirm()
    {
        _showDiscardConfirmation = false;
        await OnCancel.InvokeAsync();
    }

    private void OnDiscardCancel()
    {
        _showDiscardConfirmation = false;
    }

    private async Task CreateMission()
    {
        var createRequest = new CreateMissionDto(itemName.Trim(), itemDescription.Trim());
        var newMission = await MissionService.CreateAsync(createRequest);
        var newMissionCreated = await MissionService.GetByIdAsync(newMission.Id) != null;
        if (newMissionCreated)
        {
            await OnResult.InvokeAsync(newMission);
        }
    }

    private async Task CreateProject()
    {
        var createRequest = new CreateProjectDto(selectedParent.Id, itemName.Trim(), itemDescription.Trim());
        var newProject = await ProjectService.CreateAsync(createRequest);
        var newProjectCreated = await ProjectService.GetByIdAsync(newProject.Id) != null;
        if (newProjectCreated)
        {
            await OnResult.InvokeAsync(newProject);
        }
    }

    private async Task CreateTask()
    {
        var createRequest = new CreateTaskRequest(selectedParent.Id, itemName.Trim(), itemDescription.Trim());
        var task = await TaskService.CreateAsync(createRequest);
        var newTask = await TaskService.GetByIdAsync(task.Id);
        if (newTask is not null)
        {
            await OnResult.InvokeAsync(newTask);
        }
    }

    private bool HasSelectedParent => (ItemType == ModalType.Project || ItemType == ModalType.Task) && selectedParent is not null;
    private bool HasValidMission => ItemType == ModalType.Mission && !string.IsNullOrWhiteSpace(itemName);
}
