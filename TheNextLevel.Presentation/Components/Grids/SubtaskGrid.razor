@using TheNextLevel.Presentation.Components.Cards
@inject ITaskService TaskService

<div class="subtask-grid-header controls-container">
    <h3>Subtasks</h3>
</div>

<VirtualizedList TItem="TaskDto"
                 ItemsProvider="LoadSubtasksProvider"
                 WrapperClass="task-grid"
                 EmptyMessage="No subtasks found"
                 @ref="_list">
    <ItemTemplate Context="task">
        <TaskCard Task="task"
                  Project="null"
                  OnEditRequested="t => OnEditRequested.InvokeAsync(t)"
                  OnDeleteRequested="t => OnDeleteRequested.InvokeAsync(t)" />
    </ItemTemplate>
</VirtualizedList>

@code {
    [Parameter] public TaskDto? ParentTask { get; set; }
    [Parameter] public EventCallback<TaskDto> OnEditRequested { get; set; }
    [Parameter] public EventCallback<TaskDto> OnDeleteRequested { get; set; }

    private VirtualizedList<TaskDto>? _list;

    private async ValueTask<ItemsProviderResult<TaskDto>> LoadSubtasksProvider(ItemsProviderRequest request)
    {
        if (ParentTask == null)
            return new ItemsProviderResult<TaskDto>([], 0);

        var result = await TaskService.ListSubtasksByParentIdAsync(ParentTask.Id, request.StartIndex, request.Count);
        return new ItemsProviderResult<TaskDto>(result.Items, result.TotalCount);
    }

    public async Task RefreshList()
    {
        if (_list is not null)
            await _list.RefreshAsync();
    }
}
