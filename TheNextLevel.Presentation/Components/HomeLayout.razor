@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@using TheNextLevel.Presentation.Components.Layout

<div class="home-layout">
    <aside class="home-sidebar">
        <div class="home-logo">
            <div class="home-logo-text">Opus</div>
            <div class="home-date">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</div>
        </div>

        <nav class="home-nav">
            <button class="home-nav-btn @GetActiveClass("/missions")" @onclick='() => Navigation.NavigateTo("/missions")'>
                <svg class="home-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                <span class="home-nav-label">Missions</span>
            </button>
            <button class="home-nav-btn @GetActiveClass("/projects")" @onclick='() => Navigation.NavigateTo("/projects")'>
                <svg class="home-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                </svg>
                <span class="home-nav-label">Projects</span>
            </button>
            <button class="home-nav-btn @GetActiveClass("/tasks")" @onclick='() => Navigation.NavigateTo("/tasks")'>
                <svg class="home-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
                <span class="home-nav-label">Tasks</span>
            </button>
            <button class="home-nav-btn @GetActiveClass("/settings")" @onclick='() => Navigation.NavigateTo("/settings")'>
                <svg class="home-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="home-nav-label">Settings</span>
            </button>
        </nav>
    </aside>

    <div class="home-content-wrapper">
        <main class="home-main-content">
            @Body
        </main>
    </div>
    <BottomNav />
</div>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private string GetActiveClass(string path)
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        return currentPath == path ? "active" : "";
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
