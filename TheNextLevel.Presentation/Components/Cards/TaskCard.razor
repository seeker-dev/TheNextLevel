@using TheNextLevel.Application.DTOs
@using TheNextLevel.Application.Interfaces
@using System.Text.Json
@inject ITaskService TaskService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="task-group">
    @if (_showStatusMenu)
    {
        <div class="status-menu-backdrop" @onclick="CloseStatusMenu"></div>
        <div class="task-menu @_menuFlipClass" @ref="_menuRef" @onclick:stopPropagation="true">
            @foreach (var state in Enum.GetValues<TaskState>())
            {
                <button class="menu-item @(state == _currentStatus ? "active" : "")"
                        @onclick="() => SelectStatus(state)">
                    @GetStatusLabel(state)
                </button>
            }
        </div>
    }
    <div class="task-row @(_isCompleted ? "completed" : "") @(ShowSubtasksInline && _subtasks.Count > 0 ? "has-subtasks" : "")"
         @onclick="NavigateToDetail">
        <div class="task-stripe" style="background: @GetStripeColor(_currentStatus)"></div>
        <div class="task-body">
            <div class="task-check @(_isCompleted ? "done" : "")">
                @if (_isCompleted)
                {
                    <svg width="10" height="10" fill="none" stroke="rgba(100,180,100,0.9)" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                    </svg>
                }
            </div>
            <div class="task-text">
                <div class="task-name">@(Task?.Name ?? "Untitled")</div>
                @if (!string.IsNullOrEmpty(Task?.Description))
                {
                    <div class="desc-scroll">
                        <div class="desc-content">
                            <span class="desc-text">@Task.Description</span>
                            <span class="desc-text">@Task.Description</span>
                        </div>
                    </div>
                }
                @if (ShowSubtasksInline && _subtasks.Count > 0)
                {
                    <span class="subtask-badge">
                        <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                        </svg>
                        @_subtasks.Count subtask@(_subtasks.Count != 1 ? "s" : "")
                    </span>
                }
            </div>
            <div class="status-btn-container" @onclick:stopPropagation="true">
                <span class="status-pill @GetPillClass(_currentStatus)" @onclick="ToggleStatusMenu">
                    @GetStatusLabel(_currentStatus)
                </span>
            </div>
        </div>
        <div class="task-controls">
            @if (_editEnabled)
            {
                <button class="task-menu-btn" title="Edit Task" @onclick="RequestEdit" @onclick:stopPropagation="true">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                </button>
            }
            @if (_deleteEnabled)
            {
                <button class="task-menu-btn" title="Delete Task" @onclick="RequestDelete" @onclick:stopPropagation="true">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                </button>
            }
            @if (!_isSubtask)
            {
                <svg class="chevron" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 18l6-6-6-6"/>
                </svg>
            }
        </div>
    </div>

    @if (ShowSubtasksInline && _subtasks.Count > 0)
    {
        @for (var i = 0; i < _subtasks.Count; i++)
        {
            var subtask = _subtasks[i];
            var isLast = i == _subtasks.Count - 1;
            <SubtaskRow Task="subtask" IsLast="isLast" />
        }
    }
</div>

@code {
    [Parameter] public TaskDto? Task { get; set; }
    [Parameter] public ProjectDto? Project { get; set; }
    [Parameter] public bool ShowSubtasksInline { get; set; }
    [Parameter] public EventCallback<TaskDto> OnEditRequested { get; set; }
    [Parameter] public EventCallback<TaskDto> OnDeleteRequested { get; set; }

    private bool _editEnabled => OnEditRequested.HasDelegate;
    private bool _deleteEnabled => OnDeleteRequested.HasDelegate;

    private TaskState _currentStatus;
    private bool _showStatusMenu;
    private List<TaskDto> _subtasks = [];
    private int _loadedSubtasksForTaskId = -1;

    private ElementReference _menuRef;
    private string _menuFlipClass = "";
    private bool _menuMeasured;

    private bool _isCompleted => _currentStatus == TaskState.Completed;
    private bool _isSubtask => Task?.ParentTaskId != null;

    protected override async Task OnParametersSetAsync()
    {
        _currentStatus = Task?.Status ?? TaskState.Inactive;

        if (ShowSubtasksInline && Task != null && !_isSubtask && Task.Id != _loadedSubtasksForTaskId)
        {
            var result = await TaskService.ListSubtasksByParentIdAsync(Task.Id, 0, 100);
            _subtasks = result.Items.ToList();
            _loadedSubtasksForTaskId = Task.Id;
        }
    }

    private static string GetStripeColor(TaskState status) => status switch
    {
        TaskState.Active    => "rgba(205,133,63,0.75)",
        TaskState.Completed => "rgba(100,180,100,0.6)",
        TaskState.OnHold    => "rgba(200,150,50,0.55)",
        _                   => "rgba(80,80,80,0.5)"
    };

    private static string GetPillClass(TaskState status) => status switch
    {
        TaskState.Active    => "active",
        TaskState.Completed => "completed",
        TaskState.OnHold    => "onhold",
        _                   => "inactive"
    };

    private static string GetStatusLabel(TaskState status) => status switch
    {
        TaskState.Active    => "Active",
        TaskState.Completed => "Completed",
        TaskState.OnHold    => "On Hold",
        _                   => "Inactive"
    };

    private void ToggleStatusMenu()
    {
        _showStatusMenu = !_showStatusMenu;
        if (_showStatusMenu) { _menuFlipClass = ""; _menuMeasured = false; }
    }

    private void CloseStatusMenu() => _showStatusMenu = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_showStatusMenu && !_menuMeasured)
        {
            _menuMeasured = true;
            var flipClass = await JS.InvokeAsync<string>("getMenuFlipClass", _menuRef);
            if (flipClass != _menuFlipClass)
            {
                _menuFlipClass = flipClass;
                StateHasChanged();
            }
        }
    }

    private async Task SelectStatus(TaskState state)
    {
        if (Task == null) return;
        _showStatusMenu = false;
        await TaskService.SetStatusAsync(Task.Id, state);
        _currentStatus = state;
        StateHasChanged();
    }

    private async Task RequestEdit()
    {
        if (Task != null) await OnEditRequested.InvokeAsync(Task);
    }

    private async Task RequestDelete()
    {
        if (Task != null) await OnDeleteRequested.InvokeAsync(Task);
    }

    private void NavigateToDetail()
    {
        if (Task != null && Project != null && !_isSubtask)
        {
            var projectJson = JsonSerializer.Serialize(Project);
            Navigation.NavigateTo($"/task/{Task.Id}",
                new NavigationOptions { HistoryEntryState = projectJson });
        }
    }
}
