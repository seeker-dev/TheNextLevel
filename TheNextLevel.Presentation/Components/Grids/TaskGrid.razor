@using TheNextLevel.Presentation.Components.Cards
@inject ITaskService TaskService

<VirtualizedList TItem="TaskDto"
                 ItemsProvider="LoadTasksProvider"
                 WrapperClass="task-list"
                 EmptyMessage="No tasks found"
                 @ref="_list">
    <ItemTemplate Context="task">
        <TaskCard Task="task"
                  Project="Project"
                  ShowSubtasksInline="true"
                  OnEditRequested="t => OnEditRequested.InvokeAsync(t)"
                  OnDeleteRequested="t => OnDeleteRequested.InvokeAsync(t)" />
    </ItemTemplate>
</VirtualizedList>

@code {
    [Parameter] public ProjectDto? Project { get; set; }
    [Parameter] public string FilterStatus { get; set; } = "all";
    [Parameter] public EventCallback<TaskDto> OnEditRequested { get; set; }
    [Parameter] public EventCallback<TaskDto> OnDeleteRequested { get; set; }

    private VirtualizedList<TaskDto>? _list;
    private string _prevFilter = "all";

    protected override async Task OnParametersSetAsync()
    {
        if (_prevFilter != FilterStatus)
        {
            _prevFilter = FilterStatus;
            await RefreshList();
        }
    }

    private async ValueTask<ItemsProviderResult<TaskDto>> LoadTasksProvider(ItemsProviderRequest request)
    {
        if (Project == null)
            return new ItemsProviderResult<TaskDto>([], 0);

        var result = await TaskService.ListByProjectAsync(Project.Id, 0, 1000);
        var filtered = FilterStatus == "all"
            ? result.Items.ToList()
            : result.Items.Where(MatchesFilter).ToList();
        var page = filtered.Skip(request.StartIndex).Take(request.Count);
        return new ItemsProviderResult<TaskDto>(page, filtered.Count);
    }

    private bool MatchesFilter(TaskDto t) => FilterStatus switch
    {
        "active"    => t.Status == TaskState.Active,
        "inactive"  => t.Status == TaskState.Inactive,
        "onhold"    => t.Status == TaskState.OnHold,
        "completed" => t.Status == TaskState.Completed,
        _           => true
    };

    public async Task RefreshList()
    {
        if (_list is not null)
            await _list.RefreshAsync();
    }
}
