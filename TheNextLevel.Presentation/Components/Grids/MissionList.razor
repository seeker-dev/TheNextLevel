@using TheNextLevel.Presentation.Components.Cards
@inject IMissionService MissionService

<VirtualizedList TItem="MissionDto"
                 ItemsProvider="LoadMissionsProvider"
                 EmptyMessage="No missions available"
                 @ref="_list">
    <ItemTemplate Context="mission">
        <MissionCard Mission="mission" />
    </ItemTemplate>
</VirtualizedList>

@code {
    private VirtualizedList<MissionDto>? _list;

    private async ValueTask<ItemsProviderResult<MissionDto>> LoadMissionsProvider(ItemsProviderRequest request)
    {
        var result = await MissionService.ListAsync(request.StartIndex, request.Count);
        return new ItemsProviderResult<MissionDto>(result?.Items ?? [], result?.TotalCount ?? 0);
    }

    public async Task RefreshMissionsAsync()
    {
        if (_list is not null)
            await _list.RefreshAsync();
    }
}
