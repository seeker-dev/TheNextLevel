@using TheNextLevel.Application.DTOs.Projections

<div class="task-card">
    <div class="task-content">
        <div class="task-header">
            <div style="flex: 1;">
                <h3 class="task-title">@Task.Name</h3>
                <div class="task-metadata">
                    <span class="metadata-badge mission-badge">
                        <svg class="metadata-icon" viewBox="0 0 24 24">
                            <path class="icon-lightning" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                        <span class="metadata-text">@Task.MissionTitle</span>
                    </span>
                    <span class="metadata-separator">•</span>
                    <span class="metadata-badge project-badge">
                        <svg class="metadata-icon" viewBox="0 0 24 24">
                            <path class="icon-folder" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                        </svg>
                        <span class="metadata-text">@Task.ProjectTitle</span>
                    </span>
                    <span class="metadata-separator">•</span>
                    <span class="metadata-badge status-badge">
                        <svg class="metadata-icon" viewBox="0 0 24 24">
                            <path class="icon-check-circle" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="metadata-text">@Task.Status</span>
                    </span>
                </div>
            </div>
            <button class="menu-btn">
                <svg width="20" height="20" viewBox="0 0 24 24">
                    <path class="icon-menu" d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" />
                </svg>
            </button>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Task.Description))
    {
        <div class="description-banner">
            <div class="description-content">
                <span class="description-text">@Task.Description</span>
                <span class="description-text">@Task.Description</span>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TaskSummaryDto Task { get; set; } = default!;
}
