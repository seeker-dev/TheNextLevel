@inject IMissionService MissionService
@inject IProjectService ProjectService
@inject ITaskService TaskService

@if (!_isDialogVisible)
{
    return;
}

<div class="dialog-overlay visible">
    <div class="dialog-container" @onclick:stopPropagation="true">
        <div class="modal-header">
            <div class="title-group">
                <span class="eyebrow">Editing</span>
                <span class="modal-title">@_itemTypeName</span>
            </div>
            <button type="button" class="close-btn" aria-label="Close" @onclick="HideDialog">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="field-group">
                <span class="field-label">Name</span>
                <input type="text" @bind="itemName" class="opus-input" placeholder="Enter @_itemTypeName name" />
            </div>
            <div class="field-group">
                <span class="field-label">Description <span class="field-optional">optional</span></span>
                <textarea @bind="itemDescription" class="opus-textarea" placeholder="Brief description..."></textarea>
            </div>

            @if (Item is TaskDto || Item is ProjectDto)
            {
                <ParentSelector
                    @bind-SelectedId="_selectedParentId"
                    Items="_parentItems"
                    IsLoading="_isLoading"
                    Label="@_parentLabel" />
            }
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-ghost" @onclick="HideDialog">Cancel</button>
            <button type="button" class="btn-primary" @onclick="Confirm">
                <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Save
            </button>
        </div>
    </div>
</div>

<DiscardConfirmationDialog
    IsVisible="@(_showDiscardConfirmation && _isDialogVisible)"
    OnConfirm="OnDiscardConfirm"
    OnCancel="OnDiscardCancel" />

@code {
    [Parameter]
    public required IItemDto Item { get; set; }

    // Events
    [Parameter]
    public required EventCallback<IItemDto?> OnResult { get; set; }
    [Parameter]
    public required EventCallback OnCancel { get; set; }

    private bool _isLoading = false;
    private List<IItemDto> _parentItems = [];
    private string _parentLabel => Item is TaskDto ? "project" : "mission";
    private string _itemTypeName => Item.GetType().Name[..^3];

    private string _selectedParentId = string.Empty;
    private IItemDto? selectedParent => _parentItems.FirstOrDefault(p => p.Id.ToString() == _selectedParentId);

    // Pagination
    private int _currentPage = 1;
    private int _pageSize = 10;

    // Input binding
    private string itemName = string.Empty;
    private string itemDescription = string.Empty;
    private bool _isDialogVisible = false;

    // Discard confirmation
    private bool _showDiscardConfirmation = false;
    private string _originalName = string.Empty;
    private string _originalDescription = string.Empty;
    private string _originalParentId = string.Empty;
    private bool _hasUnsavedChanges =>
        itemName != _originalName ||
        itemDescription != _originalDescription ||
        _selectedParentId != _originalParentId;
    
    protected override async Task OnParametersSetAsync()
    {
        if (_isDialogVisible)
        {
            _currentPage = 0;
            _parentItems.Clear();
            await Load();
        }
    }

    public async Task Load()
    {
        itemName = Item.Name;
        itemDescription = Item.Description ?? string.Empty;

        _isLoading = true;
        try
        {
            if (Item is ProjectDto)
                _parentItems = await DialogHelper.LoadAllAsync<MissionDto>(MissionService.ListAsync, _pageSize);
            else if (Item is TaskDto)
                _parentItems = await DialogHelper.LoadAllAsync<ProjectDto>(ProjectService.ListAsync, _pageSize);

            var parent = Item switch
            {
                ProjectDto project => _parentItems.FirstOrDefault(m => m.Id == project.MissionId),
                TaskDto task => _parentItems.FirstOrDefault(p => p.Id == task.ProjectId),
                _ => null
            };
            _selectedParentId = parent?.Id.ToString() ?? string.Empty;
            _originalName = itemName;
            _originalDescription = itemDescription;
            _originalParentId = _selectedParentId;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task Confirm()
    {
        if (!(HasSelectedParent || HasValidMission))
        {
            // Show validation error (not implemented here)
            return;
        }

        if (Item is MissionDto)
        {
            await EditMission();            
        }
        else if (Item is ProjectDto)
        {
            await EditProject();
        }
        else if (Item is TaskDto)
        {
            await EditTask();
        }
    }

    private async Task EditMission()
    {
        var mission = (MissionDto)Item!;
        var updateRequest = new UpdateMissionDto
        (
            itemName,
            itemDescription,
            mission.IsCompleted
        );

        var result = await MissionService.UpdateAsync(mission.Id, updateRequest);
        if (result is not null)
        {
            
            ForceHideDialog();
            await OnResult.InvokeAsync(result);
        }
    }

    private async Task EditProject()
    {
        var project = (ProjectDto)Item!;
        var updateRequest = new UpdateProjectDto
        (
            itemName,
            itemDescription,
            selectedParent.Id,
            project.IsCompleted
        );

        var result = await ProjectService.UpdateAsync(project.Id, updateRequest);
        if (result is null)
        {
            // Show error message (not implemented here)
            return;
        }

        if (selectedParent.Id != project.MissionId)
        {
            var result2 = await ProjectService.MoveAsync(project.Id, selectedParent.Id);
            if (!result2)
            {
                // Show error message (not implemented here)
                return;
            }
        }

        ForceHideDialog();
        await OnResult.InvokeAsync(result);
    }

    private async Task EditTask()
    {
        var task = (TaskDto)Item!;
        var updateRequest = new UpdateTaskRequest
        (
            itemName,
            itemDescription,
            selectedParent.Id
        );

        var result = await TaskService.UpdateAsync(task.Id, updateRequest);
        if (result is null)
        {
            // Show error message (not implemented here)
            return;
        }
        if (selectedParent.Id != task.ProjectId)
        {
            var result2 = await TaskService.MoveAsync(task.Id, selectedParent.Id);
            if (!result2)
            {
                // Show error message (not implemented here)
                return;
            }
        }
        ForceHideDialog();
        await OnResult.InvokeAsync(result);
    }

    public void ShowDialog()
    {
        _isDialogVisible = true;
    }

    public void HideDialog()
    {
        if (_hasUnsavedChanges)
        {
            _showDiscardConfirmation = true;
            return;
        }
        _isDialogVisible = false;
    }

    private void ForceHideDialog()
    {
        _originalName = itemName;
        _originalDescription = itemDescription;
        _originalParentId = _selectedParentId;
        _isDialogVisible = false;
    }

    private void OnDiscardConfirm()
    {
        _showDiscardConfirmation = false;
        _isDialogVisible = false;
    }

    private void OnDiscardCancel()
    {
        _showDiscardConfirmation = false;
    }

    private bool HasSelectedParent => (Item is ProjectDto || Item is TaskDto) && selectedParent is not null;
    private bool HasValidMission => Item is MissionDto && !string.IsNullOrWhiteSpace(itemName);
}